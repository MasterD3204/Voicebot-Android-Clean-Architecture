<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111827"> <!-- Nền Dark Navy -->

    <!-- Status Text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Đang khởi tạo hệ thống AI..."
        android:textColor="#F9FAFB"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvUserTalk"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text=""
        android:textColor="#F9FAFB"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvStatus" />

    <TextView
        android:id="@+id/tvBotTalk"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:text=""
        android:maxLines="5"
        android:textColor="#F9FAFB"
        android:textSize="18sp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvUserTalk" />

    <!-- Metrics Panel -->
    <LinearLayout
        android:visibility="gone"
        android:id="@+id/metricsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:background="@drawable/bg_metrics"
        android:orientation="horizontal"
        android:padding="8dp"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@id/tvUserTalk">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/tvMetricQuery" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0ms" android:textColor="#10B981" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Query" android:textColor="#9CA3AF" android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/tvMetricLlm" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0ms" android:textColor="#10B981" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LLM (TTFT)" android:textColor="#9CA3AF" android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:id="@+id/tvMetricTts" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0ms" android:textColor="#10B981" android:textSize="16sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TTS (TTFA)" android:textColor="#9CA3AF" android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Chat List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomControls"
        app:layout_constraintTop_toBottomOf="@id/metricsPanel" />

    <io.github.sceneview.SceneView
        android:layout_marginTop="100dp"
        android:id="@+id/sceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️"
            android:textSize="18sp"
            android:paddingStart="14dp"
            android:visibility="visible"
            android:paddingEnd="14dp"
            app:backgroundTint="#374151"/>

        <Space android:layout_width="10dp" android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnToggleMic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎙️ Bắt đầu"
            android:enabled="false"
            app:backgroundTint="#3B82F6"/>

        <Space android:layout_width="10dp" android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnClear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Xóa &amp; Reset"
            android:enabled="false"
            android:visibility="visible"
            app:backgroundTint="#EF4444"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
